{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "types": ["node", "jest"],

    "baseUrl": "src",
    "paths": {
      "@/*": ["./*"]
    }
  },

  "include": [
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/__tests__/**/*.ts",
    "src/test/**/*"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}
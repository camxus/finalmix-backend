# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=eu-west-1
# Local dev only — use IAM roles in Lambda:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── DynamoDB ─────────────────────────────────────────────────────────────────
DYNAMODB_TABLE=mixvault-dev
DYNAMODB_ENDPOINT=http://localhost:8000   # local DynamoDB only

# ── S3 ───────────────────────────────────────────────────────────────────────
S3_BUCKET=mixvault-audio-dev
S3_PRESIGN_EXPIRES_SECONDS=3600

# ── SQS ──────────────────────────────────────────────────────────────────────
SQS_WAVEFORM_QUEUE_URL=https://sqs.eu-west-1.amazonaws.com/{account}/mixvault-waveform-dev
SQS_AI_ANALYSIS_QUEUE_URL=https://sqs.eu-west-1.amazonaws.com/{account}/mixvault-ai-dev
SQS_TRANSCODE_QUEUE_URL=https://sqs.eu-west-1.amazonaws.com/{account}/mixvault-transcode-dev
SQS_STORAGE_AUDIT_QUEUE_URL=https://sqs.eu-west-1.amazonaws.com/{account}/mixvault-audit-dev

# ── Cognito ───────────────────────────────────────────────────────────────────
COGNITO_USER_POOL_ID=eu-west-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_REGION=eu-west-1

# ── Nvidia Nemotron ───────────────────────────────────────────────────────────
NEMOTRON_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEMOTRON_BASE_URL=https://integrate.api.nvidia.com/v1
NEMOTRON_MODEL=nvidia/nemotron-3-super-120b-a12b
NEMOTRON_MAX_TOKENS=16384
NEMOTRON_REASONING_BUDGET=16384

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
SHARE_TOKEN_BYTES=24
